<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.desktop.controllers.AddCustomerController"
      spacing="10"
      prefWidth="350"
      prefHeight="400"
      style="-fx-padding: 20;">

    <Label text="Add Customer"
           style="-fx-font-size: 18px; -fx-font-weight: bold;" />

    <TextField fx:id="nameField" promptText="Name" />
    <TextField fx:id="nifField" promptText="NIF" />
    <TextField fx:id="emailField" promptText="Email" />
    <TextField fx:id="usernameField" promptText="Username" />
    <PasswordField fx:id="passwordField" promptText="Password" />

    <DatePicker fx:id="birthdatePicker" promptText="Birthdate" />

    <Button text="Save Customer" onAction="#saveCustomer" />

</VBox>