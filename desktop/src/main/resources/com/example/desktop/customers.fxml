<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.desktop.controllers.CustomerController">
   <children>
      <HBox layoutX="8.0" layoutY="10.0" prefHeight="380.0" prefWidth="583.0" spacing="10.0">
         <padding>
            <Insets top="10.0" />
         </padding>
         <children>
            <Button fx:id="btnLoad" mnemonicParsing="false" onAction="#loadCustomers" text="Load Customers" />
            <TableView fx:id="table" prefHeight="370.0" prefWidth="450.0">
              <columns>
                <TableColumn prefWidth="41.19994354248047" fx:id="colId" text="id" />
                <TableColumn prefWidth="134.0" fx:id="colName" text="name" />
                  <TableColumn prefWidth="93.60003662109375" fx:id="colEmail" text="email" />
                  <TableColumn prefWidth="87.0" fx:id="colPhone" text="phone" />
                  <TableColumn prefWidth="96.00003051757812" fx:id="colStatus" text="status" />
              </columns>
            </TableView>
         </children>
      </HBox>
   </children>
</AnchorPane>
